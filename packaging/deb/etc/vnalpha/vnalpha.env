# /etc/vnalpha/vnalpha.env — vnalpha host configuration
#
# This file is sourced by /usr/bin/vnalpha and /usr/bin/vnalpha-poc before
# launching the research CLI/TUI. All variables are exported into the
# environment of the vnalpha process and any subprocesses it spawns.
#
# dpkg treats this as a "conffile": on package upgrade, dpkg will prompt
# before overwriting this file if you have modified it.
#
# Edit this file to match your deployment. Lines starting with # are
# comments and are ignored. Blank lines are also ignored.
#
# After editing, changes take effect immediately on the next invocation
# of vnalpha or vnalpha-poc (no service restart needed).
#
# -------------------------------------------------------------------------
# DATA PLATFORM CONNECTION
# -------------------------------------------------------------------------

# URL of the local vnstock-service data API.
# The service is managed by the openstock-data-platform systemd unit.
# Change only if you are running vnstock-service on a non-default port.
VNSTOCK_SERVICE_URL=http://127.0.0.1:6900

# -------------------------------------------------------------------------
# WAREHOUSE PATH
# -------------------------------------------------------------------------

# Absolute path to the DuckDB research warehouse file.
# This directory is NEVER removed by the vnalpha package on upgrade/remove.
# Ensure the parent directory exists before running 'vnalpha init'.
VNALPHA_WAREHOUSE_PATH=/var/lib/openstock/warehouse/warehouse.duckdb

# -------------------------------------------------------------------------
# LOGGING
# -------------------------------------------------------------------------

# Log verbosity. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
VNALPHA_LOG_LEVEL=INFO

# Complete-universe/company reference for the mixed-provider FiinQuantX Gate A
# path. Keep VCI unless a separately reviewed complete reference provider is
# recorded for the deployment.
OPENSTOCK_REFERENCE_SOURCE=VCI

# -------------------------------------------------------------------------
# POC DEMO DATE
# -------------------------------------------------------------------------

# Default date used by vnalpha-poc when launched without --date.
# Format: YYYY-MM-DD
# Set to a date that has scored candidates in the warehouse so the TUI
# opens a populated view immediately.
VNALPHA_DEMO_DATE=2026-07-06

# -------------------------------------------------------------------------
# OPTIONAL: INTERNAL LLM GATEWAY (research assistant feature)
# -------------------------------------------------------------------------
# Leave these empty to disable the assistant. When unset, 'vnalpha ask'
# will return an error explaining the configuration requirement.
#
# VNALPHA_LLM_ENDPOINT and VNALPHA_LLM_MODEL connect to an OpenAI-compatible
# gateway (e.g. a local LiteLLM proxy or directly to OpenAI).
#
# The assistant is constrained to research/explanation workflows only.
# It does not generate trading signals or brokerage instructions.

# HTTP endpoint for chat completions (OpenAI-compatible)
# Example: http://127.0.0.1:7071/v1/chat/completions
VNALPHA_LLM_ENDPOINT=

# Model name to use for chat completions
# Example: provider/default-model
VNALPHA_LLM_MODEL=

# API key (leave empty if no auth is required on the local gateway)
VNALPHA_LLM_API_KEY=

# Whether to store raw LLM responses in the warehouse for audit/replay.
# Set to "true" only if you understand the storage implications.
VNALPHA_LLM_STORE_RAW=false
