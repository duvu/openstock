[Unit]
Description=OpenStock daily research-data maintenance
Wants=network-online.target openstock-data-platform.service
After=network-online.target openstock-data-platform.service

[Service]
Type=oneshot
WorkingDirectory=/var/lib/openstock
EnvironmentFile=-/etc/vnalpha/vnalpha.env
Environment=VNALPHA_LOG_ROOT=/var/log/openstock
# Keep root ownership for host maintenance while making DuckDB, knowledge,
# logs and the stable lock inode accessible to approved openstock operators.
Group=openstock
UMask=0007
ExecStart=/usr/bin/flock -n -E 75 /run/openstock-pipeline.lock /usr/bin/vnalpha maintain enqueue --date today --json
SuccessExitStatus=3
TimeoutStartSec=4h
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/openstock /var/log/openstock /run
StandardOutput=journal
StandardError=journal
SyslogIdentifier=openstock-pipeline
