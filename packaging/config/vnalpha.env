# /etc/vnalpha/vnalpha.env
# vnalpha terminal app configuration
# Install to: /etc/vnalpha/vnalpha.env
# Used by: /usr/bin/vnalpha, /usr/bin/vnalpha-poc launchers
#
# The Docker worker and the terminal package must resolve the same warehouse.
# Root docker-compose.yml binds OPENSTOCK_WAREHOUSE_DIR to /warehouse and the
# worker uses /warehouse/warehouse.duckdb; this host-side path is the same file.

VNSTOCK_SERVICE_URL=http://127.0.0.1:6900
VNALPHA_WAREHOUSE_PATH=/var/lib/openstock/warehouse/warehouse.duckdb
VNALPHA_PROVISIONING_QUEUE_PATH=/var/lib/openstock/queue/provisioning.sqlite3
VNALPHA_LOG_LEVEL=INFO

# Optional internal LLM gateway. The assistant remains disabled until endpoint,
# dedicated API key and a verified model ID are configured. Do not ship placeholder model
# names because they make deployment failures look like routing failures.
# After configuring, run `vnalpha preflight` (or `openstock-verify`) to verify
# the single MVP1 route; it emits a typed, secret-free readiness diagnostic and
# natural-language chat stays disabled while deterministic commands keep working.
VNALPHA_LLM_ENDPOINT=
VNALPHA_LLM_MODEL=
VNALPHA_LLM_API_KEY=
VNALPHA_LLM_STORE_RAW=false

# Optional distinct routes. Set only to model IDs verified in the deployed
# ya-router. When omitted, /model status truthfully reports single_model mode.
# VNALPHA_MODEL_SMALL=
# VNALPHA_MODEL_DEFAULT=
# VNALPHA_MODEL_REASONING=
# VNALPHA_MODEL_LONG_CONTEXT=
#
# Strict JSON Schema fallback is opt-in per profile. List json_schema only for
# aliases verified against the deployed gateway. Undeclared capability remains
# unsupported and is never guessed from a model/provider name.
# VNALPHA_MODEL_CAPABILITIES_SMALL=
# VNALPHA_MODEL_CAPABILITIES_DEFAULT=
# VNALPHA_MODEL_CAPABILITIES_REASONING=
# VNALPHA_MODEL_CAPABILITIES_LONG_CONTEXT=

VNALPHA_DEMO_DATE=today
