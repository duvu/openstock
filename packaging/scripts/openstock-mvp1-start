#!/usr/bin/env bash
# openstock-mvp1-start — one-command MVP1 chat vertical-slice startup for a
# single Linux host.
#
# Usage: openstock-mvp1-start [--no-launch] [--skip-preflight] [--help]
#   --no-launch      Do everything except launch the TUI; print the exact
#                    launch command instead (useful for headless/CI hosts).
#   --skip-preflight Skip the read-only openstock-verify --mvp1 preflight.
#   --help           Show this help message.
#
# It is idempotent: it validates/creates persistent directories, verifies or
# starts vnstock-service, migrates the warehouse (never overwriting valid data),
# checks knowledge/log paths, runs the MVP1 preflight, then launches the TUI or
# prints the exact launch command. Blockers exit non-zero with remediation.
#
# Install: sudo install -m 0755 packaging/scripts/openstock-mvp1-start /usr/bin/
set -uo pipefail

RUN_ID="mvp1start_$(date -u +%Y%m%dT%H%M%S)_$$"
LOG_ROOT="${VNALPHA_LOG_ROOT:-${HOME}/.local/state/openstock/logs}"
LOG_DIR="${LOG_ROOT}/runs/${RUN_ID}"
mkdir -p "${LOG_DIR}" 2>/dev/null || true

_json_escape() {
  local s="$1"
  printf '%s' "$s" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g' | tr -d '\000-\031'
}

log_jsonl() {
  local event_type="$1"
  local summary="${2:-}"
  local status="${3:-OK}"
  local escaped_summary
  escaped_summary="$(_json_escape "${summary}")"
  printf '{"ts":"%s","event_type":"%s","run_id":"%s","correlation_id":"%s","summary":"%s","status":"%s"}\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    "${event_type}" \
    "${RUN_ID}" \
    "${RUN_ID}" \
    "${escaped_summary}" \
    "${status}" >> "${LOG_DIR}/commands.jsonl" 2>/dev/null || true
}

# --- source env if available (never overrides an already-set variable) ---
if [ -f /etc/openstock/openstock.env ]; then
  # shellcheck source=/dev/null
  set -a
  . /etc/openstock/openstock.env
  set +a
fi

# --- config ---
VNSTOCK_SERVICE_BASE="${VNSTOCK_SERVICE_URL:-http://127.0.0.1:6900}"
VNSTOCK_HEALTHZ_URL="${VNSTOCK_SERVICE_BASE}/healthz"
WAREHOUSE_DIR="${OPENSTOCK_WAREHOUSE_DIR:-/var/lib/openstock/warehouse}"
KNOWLEDGE_ROOT="${VNALPHA_KNOWLEDGE_ROOT:-/var/lib/openstock/knowledge}"
DEMO_DATE="${VNALPHA_DEMO_DATE:-today}"
HEALTH_WAIT_SECONDS="${OPENSTOCK_HEALTH_WAIT_SECONDS:-60}"

NO_LAUNCH=false
SKIP_PREFLIGHT=false

for arg in "$@"; do
  case "$arg" in
    --no-launch)      NO_LAUNCH=true ;;
    --skip-preflight) SKIP_PREFLIGHT=true ;;
    --help)
      echo "Usage: openstock-mvp1-start [--no-launch] [--skip-preflight] [--help]"
      echo ""
      echo "Options:"
      echo "  --no-launch      Prepare everything, then print the TUI launch command."
      echo "  --skip-preflight Skip the openstock-verify --mvp1 preflight."
      echo "  --help           Show this help message."
      exit 0
      ;;
    *)
      echo "Unknown option: $arg" >&2
      echo "Run openstock-mvp1-start --help for usage." >&2
      exit 1
      ;;
  esac
done

info()  { echo "[INFO] $*"; log_jsonl "MVP1_START_STEP" "$*" "OK"; }
step()  { echo "[STEP] $*"; log_jsonl "MVP1_START_STEP" "$*" "STARTED"; }
die()   { echo "[FAIL] $*" >&2; log_jsonl "MVP1_START_FAILED" "$*" "FAILED"; exit 1; }

log_jsonl "MVP1_START_STARTED" "openstock-mvp1-start started" "STARTED"
echo "openstock-mvp1-start — MVP1 chat vertical-slice startup"
echo ""

# --- 1. validate/create persistent directories (idempotent, safe perms) ---
step "Validating persistent directories"
for dir in "$WAREHOUSE_DIR" "$KNOWLEDGE_ROOT" "$LOG_ROOT"; do
  if [ -d "$dir" ]; then
    info "directory present: $dir"
  elif mkdir -p "$dir" 2>/dev/null; then
    chmod 0775 "$dir" 2>/dev/null || true
    info "created directory: $dir"
  else
    die "cannot create required directory: $dir (check permissions/ownership)"
  fi
  [ -w "$dir" ] || die "directory not writable: $dir (fix permissions)"
done

# --- 2. start or verify vnstock-service ---
step "Ensuring vnstock-service is available"
_compose=()
if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
  _compose=(docker compose)
elif command -v docker-compose >/dev/null 2>&1; then
  _compose=(docker-compose)
fi

_healthy() {
  command -v curl >/dev/null 2>&1 || return 1
  local code
  code="$(curl --max-time 5 --silent --output /dev/null --write-out '%{http_code}' "${VNSTOCK_HEALTHZ_URL}" 2>/dev/null || true)"
  [ "$code" = "200" ]
}

if _healthy; then
  info "vnstock-service already healthy at ${VNSTOCK_HEALTHZ_URL}"
elif [ "${#_compose[@]}" -gt 0 ]; then
  info "starting vnstock-service via '${_compose[*]} up -d vnstock-service'"
  "${_compose[@]}" up -d vnstock-service >/dev/null 2>&1 || die "failed to start vnstock-service via compose"
  # Wait (bounded) for health.
  waited=0
  until _healthy; do
    [ "$waited" -ge "$HEALTH_WAIT_SECONDS" ] && die "vnstock-service did not become healthy within ${HEALTH_WAIT_SECONDS}s at ${VNSTOCK_HEALTHZ_URL}"
    sleep 2
    waited=$(( waited + 2 ))
  done
  info "vnstock-service healthy after ${waited}s"
else
  die "docker compose not found and vnstock-service is not healthy — install Docker Compose or start the service"
fi

# --- 3. initialize/migrate the warehouse (idempotent) ---
step "Ensuring warehouse migrations are applied"
if command -v vnalpha >/dev/null 2>&1; then
  vnalpha init >/dev/null 2>&1 || die "vnalpha init failed — inspect logs in ${LOG_DIR}"
  info "warehouse migrations applied (vnalpha init is idempotent)"
elif [ "${#_compose[@]}" -gt 0 ]; then
  "${_compose[@]}" --profile job run --rm vnalpha-worker init >/dev/null 2>&1 || die "worker warehouse init failed"
  info "warehouse migrations applied via vnalpha-worker"
else
  die "no vnalpha CLI or docker compose available to migrate the warehouse"
fi

# --- 4. run the read-only MVP1 preflight ---
if "$SKIP_PREFLIGHT"; then
  info "skipping preflight (--skip-preflight)"
else
  step "Running MVP1 preflight (openstock-verify --mvp1)"
  _verify=""
  script_dir="$(dirname "$0")"
  for cand in "$(command -v openstock-verify 2>/dev/null)" "${script_dir}/openstock-verify"; do
    if [ -n "$cand" ] && [ -f "$cand" ]; then _verify="$cand"; break; fi
  done
  if [ -n "$_verify" ]; then
    if bash "$_verify" --mvp1; then
      info "MVP1 preflight PASS"
    else
      die "MVP1 preflight reported blockers — resolve them and re-run"
    fi
  else
    info "openstock-verify not found; skipping preflight"
  fi
fi

# --- 5. launch the TUI or print the exact command ---
launch_cmd="vnalpha tui --date ${DEMO_DATE}"
log_jsonl "MVP1_START_COMPLETED" "startup ready; launch=${launch_cmd}" "OK"
echo ""
if "$NO_LAUNCH"; then
  echo "[READY] MVP1 startup complete. Launch the TUI with:"
  echo "    ${launch_cmd}"
  exit 0
fi

if ! command -v vnalpha >/dev/null 2>&1; then
  echo "[READY] MVP1 startup complete, but the 'vnalpha' CLI is not on PATH."
  echo "    Launch the TUI with: ${launch_cmd}"
  exit 0
fi

echo "[READY] Launching the TUI: ${launch_cmd}"
exec vnalpha tui --date "${DEMO_DATE}"
