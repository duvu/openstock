#!/usr/bin/env bash
# openstock-verify — post-deploy verification script
# Usage: openstock-verify [--ci] [--init] [--help]
#   --ci     CI mode: skip live network/service checks
#   --init   Initialize warehouse if not found (runs vnalpha init via docker compose)
set -uo pipefail
umask 077

OPENSTOCK_ENV_FILE="${OPENSTOCK_ENV_FILE:-/etc/openstock/openstock.env}"
VNALPHA_ENV_FILE="${VNALPHA_ENV_FILE:-/etc/vnalpha/vnalpha.env}"
if [ -e "$OPENSTOCK_ENV_FILE" ] && [ ! -r "$OPENSTOCK_ENV_FILE" ]; then
  echo "openstock-verify: cannot read $OPENSTOCK_ENV_FILE" >&2
  exit 1
fi
if [ -e "$VNALPHA_ENV_FILE" ] && [ ! -r "$VNALPHA_ENV_FILE" ]; then
  echo "openstock-verify: cannot read $VNALPHA_ENV_FILE; add the operator to the openstock group" >&2
  exit 1
fi
if [ -f "$OPENSTOCK_ENV_FILE" ]; then
  set -a
  . "$OPENSTOCK_ENV_FILE"
  set +a
fi
if [ -f "$VNALPHA_ENV_FILE" ]; then
  set -a
  . "$VNALPHA_ENV_FILE"
  set +a
fi

RUN_ID="verify_$(date -u +%Y%m%dT%H%M%S)_$$"
LOG_ROOT="${VNALPHA_LOG_ROOT:-${HOME}/.local/state/openstock/logs}"
if [ -L "$LOG_ROOT" ]; then
  echo "openstock-verify: refusing symlink log root: $LOG_ROOT" >&2
  exit 1
fi
LOG_DIR="${LOG_ROOT}/runs/${RUN_ID}"
mkdir -p "${LOG_ROOT}/runs" 2>/dev/null || {
  echo "openstock-verify: cannot create log root" >&2
  exit 1
}
mkdir "${LOG_DIR}" 2>/dev/null || {
  echo "openstock-verify: refusing existing or unwritable run log directory" >&2
  exit 1
}
chmod 0700 "${LOG_DIR}" 2>/dev/null || true

_json_escape() {
  local s="$1"
  printf '%s' "$s" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g' | tr -d '\000-\031'
}

log_jsonl() {
  local event_type="$1"
  local summary="${2:-}"
  local status="${3:-OK}"
  local escaped_summary
  escaped_summary="$(_json_escape "${summary}")"
  printf '{"ts":"%s","event_type":"%s","run_id":"%s","correlation_id":"%s","summary":"%s","status":"%s"}\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    "${event_type}" \
    "${RUN_ID}" \
    "${RUN_ID}" \
    "${escaped_summary}" \
    "${status}" >> "${LOG_DIR}/commands.jsonl" 2>/dev/null || true
}

# Current check name — set by each check_* function (task 7.8)
_CURRENT_CHECK=""

log_jsonl "VERIFY_STARTED" "openstock-verify started" "STARTED"

# --- config ---
VNSTOCK_SERVICE_BASE="${VNSTOCK_SERVICE_URL:-http://127.0.0.1:6900}"
VNSTOCK_HEALTHZ_URL="${VNSTOCK_SERVICE_BASE}/healthz"
WAREHOUSE_PATH="${VNALPHA_WAREHOUSE_PATH:-${OPENSTOCK_WAREHOUSE_PATH:-/var/lib/openstock/warehouse/warehouse.duckdb}}"
WAREHOUSE_DIR="${OPENSTOCK_WAREHOUSE_DIR:-$(dirname "$WAREHOUSE_PATH")}"
LOCK_FILE="${OPENSTOCK_LOCK_FILE:-/run/openstock-pipeline.lock}"
KNOWLEDGE_ROOT="${VNALPHA_KNOWLEDGE_ROOT:-/var/lib/openstock/knowledge}"
LOG_ROOT_DIR="${VNALPHA_LOG_ROOT:-${HOME}/.local/state/openstock/logs}"
MIN_FREE_DISK_MB="${OPENSTOCK_MIN_FREE_DISK_MB:-500}"

CI_MODE=false
INIT_MODE=false
MVP1_MODE=false
PASS=0
WARN=0
FAIL=0

# --- parse args ---
for arg in "$@"; do
  case "$arg" in
    --ci)   CI_MODE=true ;;
    --init) INIT_MODE=true ;;
    --mvp1) MVP1_MODE=true ;;
    --help)
      echo "Usage: openstock-verify [--ci] [--init] [--mvp1] [--help]"
      echo ""
      echo "Options:"
      echo "  --ci     CI mode: skip live Docker/network checks"
      echo "  --init   Initialize warehouse if not found"
      echo "  --mvp1   Read-only MVP1 chat vertical-slice preflight"
      echo "  --help   Show this help message"
      exit 0
      ;;
    *)
      echo "Unknown option: $arg" >&2
      echo "Run openstock-verify --help for usage." >&2
      exit 1
      ;;
  esac
done

# --- helper functions ---
ok()   { echo "[OK]   $*"; PASS=$(( PASS + 1 )); log_jsonl "VERIFY_CHECK_PASSED"  "check=${_CURRENT_CHECK} details=$*" "OK"; }
warn() { echo "[WARN] $*"; WARN=$(( WARN + 1 )); log_jsonl "VERIFY_CHECK_WARNED"  "check=${_CURRENT_CHECK} details=$*" "WARN"; }
fail() { echo "[FAIL] $*"; FAIL=$(( FAIL + 1 )); log_jsonl "VERIFY_CHECK_FAILED"  "check=${_CURRENT_CHECK} details=$*" "FAILED"; }
skip() { echo "[SKIP] $*";                         log_jsonl "VERIFY_CHECK_SKIPPED" "check=${_CURRENT_CHECK} details=$*" "SKIPPED"; }
truthy() {
  case "${1,,}" in
    1|true|yes|on) return 0 ;;
    *) return 1 ;;
  esac
}
# --- check 6.2: docker binary + docker compose ---
check_docker() {
  _CURRENT_CHECK="check_docker"
  if ! command -v docker > /dev/null 2>&1; then
    fail "docker binary not found in PATH"
    return
  fi
  ok "docker binary found: $(docker --version 2>/dev/null | head -1)"

  if docker compose version > /dev/null 2>&1; then
    ok "docker compose (plugin V2) found: $(docker compose version 2>/dev/null | head -1)"
  elif command -v docker-compose > /dev/null 2>&1; then
    ok "docker-compose (standalone legacy) found: $(docker-compose --version 2>/dev/null | head -1)"
  else
    fail "neither 'docker compose' plugin nor 'docker-compose' standalone found"
  fi
}

# --- check 6.3: systemd openstock-data-platform service ---
check_systemd() {
  _CURRENT_CHECK="check_systemd"
  if "$CI_MODE"; then
    skip "systemd check (--ci mode)"
    return
  fi

  if ! command -v systemctl > /dev/null 2>&1; then
    skip "systemd check (systemctl not available on this host)"
    return
  fi

  local status
  status="$(systemctl is-active openstock-data-platform 2>/dev/null || true)"
  if [ "$status" = "active" ]; then
    ok "openstock-data-platform systemd service is active"
  else
    warn "openstock-data-platform systemd service status: ${status:-unknown} (may not be installed yet)"
  fi

  local timer_load timer_enabled timer_active service_result service_exit
  timer_load="$(systemctl show openstock-daily-pipeline.timer -p LoadState --value 2>/dev/null || true)"
  if [ "$timer_load" = "loaded" ]; then
    timer_enabled="$(systemctl is-enabled openstock-daily-pipeline.timer 2>/dev/null || true)"
    timer_active="$(systemctl is-active openstock-daily-pipeline.timer 2>/dev/null || true)"
    service_result="$(systemctl show openstock-daily-pipeline.service -p Result --value 2>/dev/null || true)"
    service_exit="$(systemctl show openstock-daily-pipeline.service -p ExecMainStatus --value 2>/dev/null || true)"
    ok "daily timer installed enabled=${timer_enabled:-unknown} active=${timer_active:-unknown} last_result=${service_result:-unknown} last_exit=${service_exit:-unknown}"
  else
    warn "daily timer is not installed"
  fi
}

# --- check 6.4: vnstock-service container running ---
check_container() {
  _CURRENT_CHECK="check_container"
  if "$CI_MODE"; then
    skip "container status check (--ci mode)"
    return
  fi

  local compose_cmd
  if docker compose version > /dev/null 2>&1; then
    compose_cmd="docker compose"
  elif command -v docker-compose > /dev/null 2>&1; then
    compose_cmd="docker-compose"
  else
    warn "container status check skipped: no docker compose available"
    return
  fi

  local ps_output
  if ps_output="$($compose_cmd ps vnstock-service 2>/dev/null)"; then
    if echo "$ps_output" | grep -q "running\|Up"; then
      ok "vnstock-service container is running"
    else
      warn "vnstock-service container does not appear to be running"
    fi
  else
    warn "could not query vnstock-service container status (compose may not be configured here)"
  fi
}

# --- check 6.5: healthz endpoint ---
check_healthz() {
  _CURRENT_CHECK="check_healthz"
  if "$CI_MODE"; then
    skip "healthz check (--ci mode): ${VNSTOCK_HEALTHZ_URL}"
    return
  fi

  if ! command -v curl > /dev/null 2>&1; then
    fail "curl not found — cannot check healthz endpoint"
    return
  fi

  local http_code
  http_code="$(curl --max-time 10 --silent --output /dev/null --write-out '%{http_code}' "${VNSTOCK_HEALTHZ_URL}" 2>/dev/null || true)"

  if [ "$http_code" = "200" ]; then
    ok "vnstock-service healthz returned HTTP 200 (${VNSTOCK_HEALTHZ_URL})"
  else
    fail "vnstock-service healthz returned HTTP ${http_code:-000} (expected 200) at ${VNSTOCK_HEALTHZ_URL}"
  fi
}

# --- check 6.6: forbidden endpoints return 404 ---
check_forbidden() {
  _CURRENT_CHECK="check_forbidden"
  if "$CI_MODE"; then
    skip "forbidden endpoint checks (--ci mode)"
    return
  fi

  if ! command -v curl > /dev/null 2>&1; then
    fail "curl not found — cannot check forbidden endpoints"
    return
  fi

  local base_url
  base_url="${VNSTOCK_SERVICE_BASE}"

  local endpoint http_code

  for endpoint in /v1/order /v1/account /v1/portfolio /v1/trading; do
    http_code="$(curl --max-time 5 --silent --output /dev/null --write-out '%{http_code}' "${base_url}${endpoint}" 2>/dev/null || true)"
    if [ "$http_code" = "404" ]; then
      ok "forbidden endpoint ${endpoint} returns 404 (safety boundary OK)"
    else
      fail "forbidden endpoint ${endpoint} returned HTTP ${http_code:-000} (expected 404 — safety boundary BREACH)"
    fi
  done
}

# --- check 6.7: warehouse directory exists ---
check_warehouse_dir() {
  _CURRENT_CHECK="check_warehouse_dir"
  if [ -d "$WAREHOUSE_DIR" ]; then
    ok "warehouse directory exists: ${WAREHOUSE_DIR}"
  else
    warn "warehouse directory not found: ${WAREHOUSE_DIR} (required for full deployment)"
  fi
}

# --- check 6.8: warehouse file exists or init ---
check_warehouse_init() {
  _CURRENT_CHECK="check_warehouse_init"
  if [ -f "$WAREHOUSE_PATH" ]; then
    ok "warehouse file exists: ${WAREHOUSE_PATH}"
    return
  fi

  if ! "$INIT_MODE"; then
    warn "warehouse file not found: ${WAREHOUSE_PATH} (run with --init to initialize)"
    return
  fi

  if "$CI_MODE"; then
    skip "warehouse init skipped (--ci mode)"
    return
  fi

  echo "[INFO] warehouse not found — attempting initialization..."

  # Try docker compose run --rm vnalpha-worker init first
  local compose_cmd
  if docker compose version > /dev/null 2>&1; then
    compose_cmd="docker compose"
  elif command -v docker-compose > /dev/null 2>&1; then
    compose_cmd="docker-compose"
  else
    compose_cmd=""
  fi

  local init_ok=false

  if [ -n "$compose_cmd" ]; then
    if $compose_cmd run --rm vnalpha-worker init 2>/dev/null; then
      init_ok=true
    fi
  fi

  # Fallback: host vnalpha init
  if ! "$init_ok" && command -v vnalpha > /dev/null 2>&1; then
    if vnalpha init 2>/dev/null; then
      init_ok=true
    fi
  fi

  if "$init_ok"; then
    if [ -f "$WAREHOUSE_PATH" ]; then
      ok "warehouse initialized: ${WAREHOUSE_PATH}"
    else
      warn "init command ran but warehouse file still not found at: ${WAREHOUSE_PATH}"
    fi
  else
    warn "warehouse init failed — check vnalpha-worker container or host vnalpha install"
  fi
}

# --- check 6.9: pipeline smoke test ---
check_pipeline_smoke() {
  _CURRENT_CHECK="check_pipeline_smoke"
  if [[ "$CI_MODE" == "true" ]]; then
    skip "6.9 Pipeline smoke test (--ci mode)"
    return
  fi
  local demo_date="${OPENSTOCK_DEMO_DATE:-2026-07-06}"
  local cmd=""
  if command -v docker &>/dev/null && docker compose version &>/dev/null 2>&1; then
    cmd="docker compose run --rm vnalpha-worker"
  elif command -v vnalpha &>/dev/null; then
    cmd="vnalpha"
  else
    warn "6.9 Pipeline smoke test: neither docker compose nor host vnalpha available"
    return
  fi
  if $cmd watchlist --date "$demo_date" &>/dev/null 2>&1; then
    ok "6.9 Pipeline smoke test: watchlist for $demo_date succeeded"
  else
    warn "6.9 Pipeline smoke test: watchlist returned non-zero (data may not be synced)"
  fi
}

# --- check 6.10: vnalpha --help ---
check_vnalpha_help() {
  _CURRENT_CHECK="check_vnalpha_help"
  if command -v vnalpha &>/dev/null; then
    if vnalpha --help &>/dev/null 2>&1; then
      ok "6.10 vnalpha --help: OK"
    else
      warn "6.10 vnalpha --help: failed (package may need reinstall)"
    fi
  else
    warn "6.10 vnalpha not found on PATH (Debian package not installed)"
  fi
}

# --- check 6.11: vnalpha watchlist ---
check_vnalpha_watchlist() {
  _CURRENT_CHECK="check_vnalpha_watchlist"
  if [[ "$CI_MODE" == "true" ]]; then
    skip "6.11 vnalpha watchlist (--ci mode)"
    return
  fi
  local demo_date="${OPENSTOCK_DEMO_DATE:-2026-07-06}"
  if ! command -v vnalpha &>/dev/null; then
    warn "6.11 vnalpha watchlist: vnalpha not installed"
    return
  fi
  if vnalpha watchlist --date "$demo_date" &>/dev/null 2>&1; then
    ok "6.11 vnalpha watchlist --date $demo_date: OK"
  else
    warn "6.11 vnalpha watchlist: non-zero exit (warehouse may not be synced)"
  fi
}

# --- check 6.12: TUI import check ---
check_tui_import() {
  _CURRENT_CHECK="check_tui_import"
  if command -v vnalpha &>/dev/null; then
    if vnalpha tui --help &>/dev/null 2>&1; then
      ok "6.12 TUI entrypoint: vnalpha tui --help OK"
      return
    fi
  fi
  local python_bin=""
  if python_bin="$(command -v python3 2>/dev/null)" || python_bin="$(command -v python 2>/dev/null)"; then
    if "$python_bin" -c "from vnalpha.tui.app import VnAlphaApp" &>/dev/null 2>&1; then
      ok "6.12 TUI import check: VnAlphaApp importable"
    else
      warn "6.12 TUI import check: VnAlphaApp not importable (package or deps issue)"
    fi
  else
    warn "6.12 TUI check: vnalpha and python3 not found"
  fi
}

# --- check 6.13: optional assistant check ---
check_assistant() {
  _CURRENT_CHECK="check_assistant"
  if [[ "$CI_MODE" == "true" ]]; then
    skip "6.13 Assistant check (--ci mode)"
    return
  fi
  if [[ -z "${VNALPHA_LLM_API_KEY:-}" ]]; then
    skip "6.13 Assistant check: VNALPHA_LLM_API_KEY not configured"
    return
  fi
  if ! command -v vnalpha &>/dev/null; then
    warn "6.13 Assistant check: vnalpha CLI not found"
    return
  fi
  # Typed, redaction-safe LLM route preflight (issue #165). Prefer it over a
  # coarse plan-preview so operators see the exact failure mode. Natural-language
  # chat being unavailable is a WARN, not a FAIL — deterministic commands work.
  if vnalpha preflight &>/dev/null 2>&1; then
    ok "6.13 Assistant check: LLM route preflight READY"
  else
    warn "6.13 Assistant check: LLM route unavailable (run 'vnalpha preflight')"
  fi
}

# --- check ci.1: docker compose config ---
check_ci_compose_config() {
  _CURRENT_CHECK="check_ci_compose_config"
  if ! "$CI_MODE"; then return; fi
  if ! command -v docker >/dev/null 2>&1; then
    skip "CI: docker compose config (docker not available)"
    return
  fi
  if docker compose config >/dev/null 2>&1; then
    ok "CI: docker compose config is valid"
  else
    fail "CI: docker compose config failed"
  fi
}

# --- check ci.2: localhost-only binding ---
check_ci_localhost_binding() {
  _CURRENT_CHECK="check_ci_localhost_binding"
  if ! "$CI_MODE"; then return; fi
  local compose_file="docker-compose.yml"
  if [ ! -f "$compose_file" ]; then
    skip "CI: localhost binding check (docker-compose.yml not found)"
    return
  fi
  if grep -q "127.0.0.1:6900" "$compose_file"; then
    ok "CI: vnstock-service binds to localhost (127.0.0.1:6900)"
  else
    fail "CI: vnstock-service does not bind to 127.0.0.1:6900 — potential safety boundary issue"
  fi
}

# --- check ci.3: vnalpha-worker is profile-gated ---
check_ci_worker_profile() {
  _CURRENT_CHECK="check_ci_worker_profile"
  if ! "$CI_MODE"; then return; fi
  local compose_file="docker-compose.yml"
  if [ ! -f "$compose_file" ]; then
    skip "CI: worker profile check (docker-compose.yml not found)"
    return
  fi
  if grep -A 5 "vnalpha-worker" "$compose_file" | grep -q "profiles:"; then
    ok "CI: vnalpha-worker is profile-gated in docker-compose.yml"
  else
    fail "CI: vnalpha-worker is NOT profile-gated — it should require explicit --profile to start"
  fi
}

# --- check ci.4: worker warehouse env/mount ---
check_ci_worker_warehouse_env() {
  _CURRENT_CHECK="check_ci_worker_warehouse_env"
  if ! "$CI_MODE"; then return; fi
  local compose_file="docker-compose.yml"
  if [ ! -f "$compose_file" ]; then
    skip "CI: worker env check (docker-compose.yml not found)"
    return
  fi
  if grep -q "VNSTOCK_SERVICE_URL" "$compose_file" && grep -q "VNALPHA_WAREHOUSE_PATH" "$compose_file"; then
    ok "CI: worker env contains VNSTOCK_SERVICE_URL and VNALPHA_WAREHOUSE_PATH"
  else
    fail "CI: docker-compose.yml missing required worker env vars (VNSTOCK_SERVICE_URL or VNALPHA_WAREHOUSE_PATH)"
  fi
}

# --- check ci.5: bash -n on deploy scripts ---
check_ci_script_syntax() {
  _CURRENT_CHECK="check_ci_script_syntax"
  if ! "$CI_MODE"; then return; fi
  local script_dir
  script_dir="$(dirname "$0")"
  local failed=0

  for script in \
    "${script_dir}/openstock-verify" \
    "${script_dir}/openstock-mvp1-start" \
    "${script_dir}/openstock-backup-warehouse" \
    "${script_dir}/openstock-restore-warehouse" \
    "${script_dir}/openstock-run-pipeline"
  do
    if [ -f "$script" ]; then
      if bash -n "$script" 2>/dev/null; then
        ok "CI: bash -n $script OK"
      else
        fail "CI: bash -n $script FAILED (syntax error)"
        failed=1
      fi
    else
      warn "CI: script not found: $script"
    fi
  done
}

# --- check ci.6: systemd-analyze verify ---
check_ci_systemd_analyze() {
  _CURRENT_CHECK="check_ci_systemd_analyze"
  if ! "$CI_MODE"; then return; fi
  if ! command -v systemd-analyze >/dev/null 2>&1; then
    skip "CI: systemd-analyze not available"
    return
  fi
  local script_dir
  script_dir="$(dirname "$0")"
  local systemd_dir="${script_dir}/../systemd"
  if [ ! -d "$systemd_dir" ]; then
    skip "CI: systemd dir not found"
    return
  fi
  local failed=0
  for unit in "$systemd_dir"/*.service "$systemd_dir"/*.timer; do
    [ -f "$unit" ] || continue
    if systemd-analyze verify "$unit" 2>/dev/null; then
      ok "CI: systemd-analyze verify $(basename "$unit") OK"
    else
      fail "CI: systemd-analyze verify $(basename "$unit") reported issues"
      failed=1
    fi
  done
}

# --- check ci.7: package metadata/launcher files ---
check_ci_package_files() {
  _CURRENT_CHECK="check_ci_package_files"
  if ! "$CI_MODE"; then return; fi
  local script_dir
  script_dir="$(dirname "$0")"
  local pkg_dir="${script_dir}/../deb"
  local failed=0

  for f in \
    "${pkg_dir}/DEBIAN/control" \
    "${pkg_dir}/usr/bin/vnalpha" \
    "${pkg_dir}/usr/bin/vnalpha-poc" \
    "${pkg_dir}/etc/vnalpha/vnalpha.env" \
    "${pkg_dir}/usr/lib/systemd/system/openstock-daily-pipeline.service" \
    "${pkg_dir}/usr/lib/systemd/system/openstock-daily-pipeline.timer"
  do
    if [ -f "$f" ]; then
      ok "CI: package file exists: $(basename "$f")"
    else
      fail "CI: package file missing: $f"
      failed=1
    fi
  done
}

# --- check ci.8: no TUI daemon configured ---
check_ci_no_tui_daemon() {
  _CURRENT_CHECK="check_ci_no_tui_daemon"
  if ! "$CI_MODE"; then return; fi
  local script_dir
  script_dir="$(dirname "$0")"
  local systemd_dir="${script_dir}/../systemd"
  if [ -d "$systemd_dir" ]; then
    if grep -r "vnalpha tui\|vnalpha-tui\|tui --daemon\|tui --headless" "$systemd_dir" 2>/dev/null; then
      fail "CI: TUI daemon found in systemd units — TUI should not run as a daemon"
    else
      ok "CI: no TUI daemon configured in systemd units"
    fi
  else
    skip "CI: systemd dir not found for TUI daemon check"
  fi
}

# ==========================================================================
# MVP1 chat vertical-slice preflight (issue #166). Read-only: every check
# reports PASS/WARN/FAIL and never mutates existing valid data or credentials.
# ==========================================================================

# --- mvp1.1: service health + version + canonical capability ---
check_mvp1_service() {
  _CURRENT_CHECK="check_mvp1_service"
  if ! command -v curl >/dev/null 2>&1; then
    fail "MVP1 service: curl not found — cannot verify vnstock-service"
    return
  fi
  local code
  code="$(curl --max-time 10 --silent --output /dev/null --write-out '%{http_code}' "${VNSTOCK_HEALTHZ_URL}" 2>/dev/null || true)"
  if [ "$code" = "200" ]; then
    ok "MVP1 service: vnstock-service healthz 200 (${VNSTOCK_HEALTHZ_URL})"
  else
    fail "MVP1 service: vnstock-service healthz HTTP ${code:-000} at ${VNSTOCK_HEALTHZ_URL} — start it with 'make up-vnstock'"
    return
  fi
  # Version/capability are best-effort: absence is a WARN, not a blocker.
  local ver_code
  ver_code="$(curl --max-time 5 --silent --output /dev/null --write-out '%{http_code}' "${VNSTOCK_SERVICE_BASE}/version" 2>/dev/null || true)"
  if [ "$ver_code" = "200" ]; then
    ok "MVP1 service: version endpoint reachable"
  else
    warn "MVP1 service: version endpoint HTTP ${ver_code:-000} (older service build)"
  fi
}

check_mvp1_fiinquantx() {
  _CURRENT_CHECK="check_mvp1_fiinquantx"
  local requested=false
  local reference_source="${OPENSTOCK_REFERENCE_SOURCE:-}"
  if truthy "${VNSTOCK_INSTALL_FIINQUANTX:-false}"; then
    requested=true
  fi
  if ! "$requested"; then
    warn "MVP1 FiinQuantX: optional Gate A path is not configured"
    return
  fi
  if [ "${reference_source^^}" != "VCI" ]; then
    fail "MVP1 FiinQuantX: OPENSTOCK_REFERENCE_SOURCE must be the reviewed VCI complete-universe/company reference provider"
    return
  fi
  local capabilities
  capabilities="$(curl --max-time 5 --silent "${VNSTOCK_SERVICE_BASE}/v1/providers/capabilities" 2>/dev/null || true)"
  if printf '%s' "$capabilities" | python3 -c '
import json
import sys

required = (
    "equity.ohlcv",
    "index.ohlcv",
    "reference.index_membership_snapshot",
    "reference.sector_membership_snapshot",
)
try:
    payload = json.load(sys.stdin)
    provider = payload["capabilities"]["FIINQUANTX"]
except (KeyError, TypeError, ValueError, json.JSONDecodeError):
    raise SystemExit(1)
if not isinstance(provider, dict):
    raise SystemExit(1)
for dataset in required:
    capability = provider.get(dataset)
    if not isinstance(capability, dict):
        raise SystemExit(1)
    if capability.get("supported") is not True:
        raise SystemExit(1)
    if capability.get("explicit_only") is not True:
        raise SystemExit(1)
'; then
    ok "MVP1 FiinQuantX: Gate A capability inventory is configured; reference source=${reference_source^^}"
  else
    fail "MVP1 FiinQuantX: service capability inventory does not expose all Gate A datasets"
  fi
}

# --- mvp1.2: warehouse path + writer-lock + free disk ---
check_mvp1_warehouse() {
  _CURRENT_CHECK="check_mvp1_warehouse"
  if [ ! -d "$WAREHOUSE_DIR" ]; then
    fail "MVP1 warehouse: directory missing: ${WAREHOUSE_DIR} — create it or run 'openstock-mvp1-start'"
    return
  fi
  if [ -w "$WAREHOUSE_DIR" ]; then
    ok "MVP1 warehouse: directory writable: ${WAREHOUSE_DIR}"
  else
    fail "MVP1 warehouse: directory not writable: ${WAREHOUSE_DIR} — fix permissions"
  fi
  if [ -f "$WAREHOUSE_PATH" ]; then
    ok "MVP1 warehouse: file present: ${WAREHOUSE_PATH}"
  else
    fail "MVP1 warehouse: file not found: ${WAREHOUSE_PATH} — run 'vnalpha init' (safe/idempotent)"
  fi
  # Free disk (read-only): WARN when below threshold so a slice run has headroom.
  local free_mb
  free_mb="$(df -Pm "$WAREHOUSE_DIR" 2>/dev/null | awk 'NR==2 {print $4}')"
  if [ -n "$free_mb" ] && [ "$free_mb" -ge "$MIN_FREE_DISK_MB" ]; then
    ok "MVP1 warehouse: free disk ${free_mb}MB (>= ${MIN_FREE_DISK_MB}MB)"
  elif [ -n "$free_mb" ]; then
    warn "MVP1 warehouse: low free disk ${free_mb}MB (< ${MIN_FREE_DISK_MB}MB)"
  else
    warn "MVP1 warehouse: could not determine free disk for ${WAREHOUSE_DIR}"
  fi
}

# --- mvp1.3: warehouse migration + writer-lock readiness (read-only) ---
check_mvp1_migrations() {
  _CURRENT_CHECK="check_mvp1_migrations"
  if [[ "$CI_MODE" == "true" ]]; then
    skip "MVP1 migrations (--ci mode)"
    return
  fi
  if [ ! -f "$WAREHOUSE_PATH" ]; then
    fail "MVP1 migrations: warehouse missing at ${WAREHOUSE_PATH}; run 'vnalpha init' before verification"
    return
  fi
  if ! command -v vnalpha >/dev/null 2>&1; then
    fail "MVP1 migrations: vnalpha CLI not found — install the candidate package to verify ${WAREHOUSE_PATH}"
    return
  fi
  if vnalpha warehouse status --path "$WAREHOUSE_PATH" --json >/dev/null 2>&1; then
    ok "MVP1 migrations: read-only schema contract verified at ${WAREHOUSE_PATH}"
  else
    fail "MVP1 migrations: warehouse is unreadable or schema-incompatible at ${WAREHOUSE_PATH}; back up valid data, then run 'vnalpha init' and retry"
  fi

  if ! command -v flock >/dev/null 2>&1; then
    fail "MVP1 writer lock: flock not found — install util-linux to inspect ${LOCK_FILE}"
    return
  fi
  if [ ! -e "$LOCK_FILE" ]; then
    ok "MVP1 writer lock: no lock file present at ${LOCK_FILE}"
    return
  fi
  if [ ! -f "$LOCK_FILE" ]; then
    fail "MVP1 writer lock: lock path is not a regular file: ${LOCK_FILE}"
    return
  fi
  local lock_fd
  if ! exec {lock_fd}<"$LOCK_FILE"; then
    fail "MVP1 writer lock: cannot inspect ${LOCK_FILE}; fix path permissions"
    return
  fi
  if flock -n "$lock_fd"; then
    flock -u "$lock_fd" 2>/dev/null || true
    ok "MVP1 writer lock: idle and inspectable at ${LOCK_FILE}"
  else
    warn "MVP1 writer lock: active writer holds ${LOCK_FILE}; retry verification after it completes"
  fi
  exec {lock_fd}<&-
}

# --- mvp1.4: knowledge path write/read readiness ---
check_mvp1_knowledge() {
  _CURRENT_CHECK="check_mvp1_knowledge"
  if [ -d "$KNOWLEDGE_ROOT" ]; then
    if [ -w "$KNOWLEDGE_ROOT" ]; then
      ok "MVP1 knowledge: path writable: ${KNOWLEDGE_ROOT}"
    else
      fail "MVP1 knowledge: path not writable: ${KNOWLEDGE_ROOT} — fix permissions"
    fi
  else
    warn "MVP1 knowledge: path not found: ${KNOWLEDGE_ROOT} — created on first projection"
  fi
}

# --- mvp1.5: LLM route preflight (issue #165) ---
check_mvp1_llm() {
  _CURRENT_CHECK="check_mvp1_llm"
  if ! command -v vnalpha >/dev/null 2>&1; then
    warn "MVP1 LLM: vnalpha CLI not found — natural-language chat unavailable"
    return
  fi
  if [ -z "${VNALPHA_LLM_API_KEY:-}" ]; then
    warn "MVP1 LLM: not configured — deterministic slash commands remain usable"
    return
  fi
  if vnalpha preflight >/dev/null 2>&1; then
    ok "MVP1 LLM: route preflight READY"
  else
    warn "MVP1 LLM: route unavailable — chat degraded; run 'vnalpha preflight'"
  fi
}

# --- mvp1.6: backup/restore commands available (issue #150) ---
check_mvp1_backup_restore() {
  _CURRENT_CHECK="check_mvp1_backup_restore"
  local script_dir found_backup="" found_restore=""
  script_dir="$(dirname "$0")"
  for cand in "$(command -v openstock-backup-warehouse 2>/dev/null)" "${script_dir}/openstock-backup-warehouse"; do
    if [ -n "$cand" ] && [ -f "$cand" ]; then found_backup="$cand"; break; fi
  done
  for cand in "$(command -v openstock-restore-warehouse 2>/dev/null)" "${script_dir}/openstock-restore-warehouse"; do
    if [ -n "$cand" ] && [ -f "$cand" ]; then found_restore="$cand"; break; fi
  done
  if [ -n "$found_backup" ]; then
    ok "MVP1 backup: openstock-backup-warehouse available"
  else
    warn "MVP1 backup: openstock-backup-warehouse not found on PATH or scripts dir"
  fi
  if [ -n "$found_restore" ]; then
    ok "MVP1 restore: openstock-restore-warehouse available"
  else
    warn "MVP1 restore: openstock-restore-warehouse not found on PATH or scripts dir"
  fi
}

# --- mvp1.7: release/version/commit metadata ---
check_mvp1_release() {
  _CURRENT_CHECK="check_mvp1_release"
  local release_file="${OPENSTOCK_RELEASE_FILE:-/opt/vnalpha/RELEASE}"
  local commit="" tree_state=""
  if [ -f "$release_file" ]; then
    commit="$(sed -n 's/^commit=//p' "$release_file" | head -1)"
    tree_state="$(sed -n 's/^tree_state=//p' "$release_file" | head -1)"
    if [[ "$commit" =~ ^[0-9a-f]{40}$ ]] && [ "$tree_state" = "clean" ]; then
      ok "MVP1 release: packaged commit ${commit:0:7} (clean)"
    else
      fail "MVP1 release: candidate metadata is not clean and exact"
    fi
    return
  fi
  if command -v git >/dev/null 2>&1 && git rev-parse HEAD >/dev/null 2>&1; then
    commit="$(git rev-parse HEAD 2>/dev/null || true)"
    local untracked_in_scope
    untracked_in_scope="$(git ls-files --others --exclude-standard 2>/dev/null | grep -v '^ya-router/' || true)"
    if [ -n "$commit" ] && git diff --quiet --ignore-submodules -- 2>/dev/null && \
       git diff --cached --quiet --ignore-submodules -- 2>/dev/null && \
       [ -z "$untracked_in_scope" ]; then
      ok "MVP1 release: source commit ${commit:0:7} (clean)"
      return
    fi
  fi
  fail "MVP1 release: exact clean candidate metadata unavailable"
}

# --- header ---
echo "openstock-verify — post-deploy verification"
echo "CI mode: ${CI_MODE}  |  Init mode: ${INIT_MODE}  |  MVP1 mode: ${MVP1_MODE}"
echo ""

# --- run checks ---
if "$MVP1_MODE"; then
  # Read-only MVP1 chat vertical-slice preflight (issue #166). Composes the
  # dependencies the chat slice needs; blockers FAIL (exit 1), optional/degraded
  # dependencies WARN. Honours --ci to stay offline for CI.
  check_mvp1_release
  if "$CI_MODE"; then
    check_ci_compose_config
    check_ci_localhost_binding
    check_vnalpha_help
    check_tui_import
    check_mvp1_backup_restore
  else
    check_docker
    check_mvp1_service
    check_mvp1_fiinquantx
    check_forbidden
    check_mvp1_warehouse
    check_mvp1_migrations
    check_mvp1_knowledge
    check_mvp1_llm
    check_mvp1_backup_restore
    check_tui_import
  fi
elif "$CI_MODE"; then
  check_ci_compose_config
  check_ci_localhost_binding
  check_ci_worker_profile
  check_ci_worker_warehouse_env
  check_ci_script_syntax
  check_ci_systemd_analyze
  check_ci_package_files
  check_ci_no_tui_daemon
  check_vnalpha_help
  check_tui_import
else
  check_docker
  check_systemd
  check_container
  check_healthz
  check_forbidden
  check_warehouse_dir
  check_warehouse_init
  check_vnalpha_help
  check_tui_import
  check_pipeline_smoke
  check_vnalpha_watchlist
  check_assistant
fi

# --- summary ---
echo ""
echo "Results: ${PASS} OK  ${WARN} WARN  ${FAIL} FAIL"

if [ "$FAIL" -eq 0 ]; then
  echo "Status: PASS"
  log_jsonl "VERIFY_RUN_COMPLETED" "openstock-verify PASS pass=${PASS} warn=${WARN} fail=${FAIL}" "OK"
  exit 0
else
  echo "Status: FAIL (${FAIL} required check(s) failed)"
  log_jsonl "VERIFY_RUN_COMPLETED" "openstock-verify FAIL pass=${PASS} warn=${WARN} fail=${FAIL}" "FAILED"
  exit 1
fi
