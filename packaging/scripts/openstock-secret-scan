#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
SCAN_HISTORY=false

usage() {
  printf '%s\n' 'Usage: openstock-secret-scan [--root PATH] [--history] [--help]'
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --root)
      [ "$#" -ge 2 ] || { usage >&2; exit 2; }
      ROOT="$(cd "$2" && pwd)"
      shift 2
      ;;
    --history)
      SCAN_HISTORY=true
      shift
      ;;
    --help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

found=0
scan_text() {
  local source="$1"
  local content="$2"
  local matches
  matches="$(printf '%s\n' "$content" | rg -n -I -U \
    -e '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----\n[A-Za-z0-9+/=]{16,}' \
    -e '(?i)(api[_-]?key|access[_-]?token|auth[_-]?token|secret[_-]?key|password|cookie|session[_-]?token)[[:space:]]*[:=][[:space:]]*(sk-[A-Za-z0-9_-]+|live-[A-Za-z0-9_-]+|ghp_[A-Za-z0-9_]+|github_pat_[A-Za-z0-9_]+|xox[baprs]-[A-Za-z0-9-]+|[A-Fa-f0-9]{32,})' || true)"
  if [ -n "$matches" ]; then
    printf '[FAIL] sensitive content in %s\n%s\n' "$source" "$matches"
    found=1
  fi
}

while IFS= read -r -d '' path; do
  scan_text "$path" "$(git -C "$ROOT" show "HEAD:$path" 2>/dev/null | tr -d '\000' || true)"
done < <(git -C "$ROOT" ls-files -z)

if "$SCAN_HISTORY"; then
  scan_text 'git-history' "$(git -C "$ROOT" log --all --no-ext-diff --binary -p 2>/dev/null || true)"
fi

if [ "$found" -ne 0 ]; then
  exit 1
fi

printf '[OK] secret scan passed\n'
