#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
SCAN_HISTORY=false

usage() {
  printf '%s\n' 'Usage: openstock-secret-scan [--root PATH] [--history] [--help]'
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --root)
      [ "$#" -ge 2 ] || { usage >&2; exit 2; }
      ROOT="$(cd "$2" && pwd)"
      shift 2
      ;;
    --history)
      SCAN_HISTORY=true
      shift
      ;;
    --help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

found=0
PATHS_FILE="$(mktemp /tmp/openstock-secret-scan-paths.XXXXXX)"
WORKTREE_PATHS_FILE="$(mktemp /tmp/openstock-secret-scan-worktree-paths.XXXXXX)"
ENUMERATION_ERRORS_FILE="$(mktemp /tmp/openstock-secret-scan-errors.XXXXXX)"
BLOB_FILE="$(mktemp /tmp/openstock-secret-scan-blob.XXXXXX)"
cleanup() {
  rm -f "$PATHS_FILE" "$WORKTREE_PATHS_FILE" "$ENUMERATION_ERRORS_FILE" "$BLOB_FILE"
}
trap cleanup EXIT

scan_text() {
  local source="$1"
  local content="$2"
  local matches
  local status
  if command -v rg >/dev/null 2>&1; then
    if matches="$(printf '%s\n' "$content" | rg -n -I -U \
      -e '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----\n[A-Za-z0-9+/=]{16,}' \
      -e '(?i)(api[_-]?key|access[_-]?token|auth[_-]?token|secret[_-]?key|password|cookie|session[_-]?token)[[:space:]]*[:=][[:space:]]*(sk-[A-Za-z0-9_-]+|live-[A-Za-z0-9_-]+|ghp_[A-Za-z0-9_]+|github_pat_[A-Za-z0-9_]+|xox[baprs]-[A-Za-z0-9-]+|[A-Fa-f0-9]{32,})')"; then
      status=0
    else
      status=$?
    fi
    if [ "$status" -gt 1 ]; then
      printf '[ERROR] secret scanner failed for %s (rg exit %d)\n' "$source" "$status" >&2
      return 2
    fi
  else
    local grep_matches
    local key_matches
    if grep_matches="$(printf '%s\n' "$content" | grep -Ein \
      '(api[_-]?key|access[_-]?token|auth[_-]?token|secret[_-]?key|password|cookie|session[_-]?token)[[:space:]]*[:=][[:space:]]*(sk-[A-Za-z0-9_-]+|live-[A-Za-z0-9_-]+|ghp_[A-Za-z0-9_]+|github_pat_[A-Za-z0-9_]+|xox[baprs]-[A-Za-z0-9-]+|[A-Fa-f0-9]{32,})')"; then
      status=0
    else
      status=$?
    fi
    if [ "$status" -gt 1 ]; then
      printf '[ERROR] secret scanner failed for %s (grep exit %d)\n' "$source" "$status" >&2
      return 2
    fi
    if ! key_matches="$(printf '%s\n' "$content" | awk '
        /-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----/ {
          header_line = NR
          if ((getline key_line) > 0 && key_line ~ /^[A-Za-z0-9+\/=]{16,}$/) {
            printf "%d:%s\n%d:%s\n", header_line, $0, NR, key_line
          }
        }
      ')"; then
      printf '[ERROR] secret scanner failed for %s (awk error)\n' "$source" >&2
      return 2
    fi
    matches="${grep_matches}${grep_matches:+$'\n'}${key_matches}"
  fi
  if [ -n "$matches" ]; then
    printf '[FAIL] sensitive content in %s at line(s): %s\n' \
      "$source" \
      "$(printf '%s\n' "$matches" | awk -F: '
        !seen[$1]++ { lines = lines (lines ? "," : "") $1 }
        END { print lines }
      ')"
    found=1
  fi
}

if ! git -C "$ROOT" ls-files -z --cached \
  >"$PATHS_FILE" 2>"$ENUMERATION_ERRORS_FILE"; then
  printf '[ERROR] secret scanner could not enumerate repository files\n' >&2
  exit 2
fi
if ! {
  git -C "$ROOT" ls-files -z --modified
  git -C "$ROOT" ls-files -z --others --exclude-standard -- . ':(exclude)ya-router/**'
} >"$WORKTREE_PATHS_FILE" 2>>"$ENUMERATION_ERRORS_FILE"; then
  printf '[ERROR] secret scanner could not enumerate worktree files\n' >&2
  exit 2
fi
if [ -s "$ENUMERATION_ERRORS_FILE" ]; then
  printf '[ERROR] secret scanner encountered unreadable repository paths\n' >&2
  exit 2
fi

while IFS= read -r -d '' path; do
  if ! git -C "$ROOT" show ":$path" >"$BLOB_FILE" 2>/dev/null; then
    printf '[ERROR] secret scanner could not read index:%s\n' "$path" >&2
    exit 2
  fi
  if grep -Iq . "$BLOB_FILE"; then
    index_text_status=0
  else
    index_text_status=$?
  fi
  if [ "$index_text_status" -eq 1 ]; then
    continue
  fi
  if [ "$index_text_status" -gt 1 ]; then
    printf '[ERROR] secret scanner could not inspect index:%s\n' "$path" >&2
    exit 2
  fi
  if ! content="$(tr -d '\000' <"$BLOB_FILE")"; then
    printf '[ERROR] secret scanner could not read index:%s\n' "$path" >&2
    exit 2
  fi
  scan_text "index:$path" "$content"
done <"$PATHS_FILE"

while IFS= read -r -d '' path; do
  worktree_path="$ROOT/$path"
  if [ -f "$worktree_path" ] && [ ! -L "$worktree_path" ]; then
    if grep -Iq . "$worktree_path"; then
      text_status=0
    else
      text_status=$?
    fi
    if [ "$text_status" -eq 1 ]; then
      continue
    fi
    if [ "$text_status" -gt 1 ]; then
      printf '[ERROR] secret scanner could not read %s\n' "$path" >&2
      exit 2
    fi
    if ! content="$(tr -d '\000' < "$worktree_path")"; then
      printf '[ERROR] secret scanner could not read %s\n' "$path" >&2
      exit 2
    fi
  else
    continue
  fi
  scan_text "worktree:$path" "$content"
done <"$WORKTREE_PATHS_FILE"

if "$SCAN_HISTORY"; then
  scan_text 'git-history' "$(git -C "$ROOT" log --all --no-ext-diff --binary -p 2>/dev/null)"
fi

if [ "$found" -ne 0 ]; then
  exit 1
fi

printf '[OK] secret scan passed\n'
