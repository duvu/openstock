#!/usr/bin/env bash
# openstock-backup-warehouse — create a verified, transaction-safe backup of the
# DuckDB warehouse and durable provisioning queue.
#
# Usage: openstock-backup-warehouse [--wait SECONDS] [--force] [--help]
#   --wait SECONDS  Block up to SECONDS waiting for the writer lock (default: 0,
#                   i.e. fail immediately if a writer holds the lock).
#   --force         Skip the backup-verification step ONLY. It does NOT bypass
#                   the writer lock: a backup is never taken while a writer job
#                   holds the exclusive pipeline lock.
#
# The backup acquires the exclusive warehouse and provisioning-worker locks,
# then publishes a paired DuckDB/SQLite snapshot only after both copies pass
# bounded read-only verification.
#
# Install: sudo install -m 0755 packaging/scripts/openstock-backup-warehouse /usr/bin/

set -uo pipefail

LOCK_FILE="${OPENSTOCK_LOCK_FILE:-/run/openstock-pipeline.lock}"
LOCK_FD=200
QUEUE_LOCK_FILE="${OPENSTOCK_PROVISIONING_LOCK_FILE:-/run/openstock-provisioner.lock}"
QUEUE_LOCK_FD=201
WAIT_SECONDS=0
FORCE=false

RUN_ID="backup_$(date -u +%Y%m%dT%H%M%S)_$$"
LOG_ROOT="${VNALPHA_LOG_ROOT:-${HOME}/.local/state/openstock/logs}"
LOG_DIR="${LOG_ROOT}/runs/${RUN_ID}"
mkdir -p "${LOG_DIR}" 2>/dev/null || true

# --- safe JSONL helper ---
_json_escape() {
  local s="$1"
  printf '%s' "$s" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g' | tr -d '\000-\031'
}

log_jsonl() {
  local event_type="$1"
  local summary="${2:-}"
  local status="${3:-OK}"
  local escaped_summary
  escaped_summary="$(_json_escape "${summary}")"
  printf '{"ts":"%s","event_type":"%s","run_id":"%s","correlation_id":"%s","summary":"%s","status":"%s"}\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    "${event_type}" \
    "${RUN_ID}" \
    "${RUN_ID}" \
    "${escaped_summary}" \
    "${status}" >> "${LOG_DIR}/commands.jsonl" 2>/dev/null || true
}

usage() {
  echo "Usage: openstock-backup-warehouse [--wait SECONDS] [--force] [--help]"
  echo "  --wait SECONDS  Block up to SECONDS waiting for the writer lock (default: 0)."
  echo "  --force         Skip backup verification only; never bypasses the writer lock."
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --force) FORCE=true; shift ;;
    --wait)
      shift
      if [ "$#" -eq 0 ] || ! printf '%s' "${1:-}" | grep -Eq '^[0-9]+$'; then
        echo "[FAIL] --wait requires a non-negative integer argument." >&2
        exit 1
      fi
      WAIT_SECONDS="$1"; shift ;;
    --wait=*)
      WAIT_SECONDS="${1#--wait=}"
      if ! printf '%s' "$WAIT_SECONDS" | grep -Eq '^[0-9]+$'; then
        echo "[FAIL] --wait requires a non-negative integer argument." >&2
        exit 1
      fi
      shift ;;
    --help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage >&2; exit 1 ;;
  esac
done

# Source platform and application env if available.
if [ -f /etc/openstock/openstock.env ]; then
  set -a
  # shellcheck source=/dev/null
  . /etc/openstock/openstock.env
  set +a
fi
if [ -f /etc/vnalpha/vnalpha.env ]; then
  set -a
  # shellcheck source=/dev/null
  . /etc/vnalpha/vnalpha.env
  set +a
fi

WAREHOUSE_PATH="${OPENSTOCK_WAREHOUSE_PATH:-/var/lib/openstock/warehouse/warehouse.duckdb}"
WAREHOUSE_DIR="${OPENSTOCK_WAREHOUSE_DIR:-/var/lib/openstock/warehouse}"
BACKUP_DIR="${WAREHOUSE_DIR}/backups"
QUEUE_PATH="${OPENSTOCK_QUEUE_PATH:-${VNALPHA_PROVISIONING_QUEUE_PATH:-/var/lib/openstock/queue/provisioning.sqlite3}}"

# --- bounded, read-only integrity verification of a DuckDB file ---
# Opens the file read-only, then full-scans every user table so that
# block-level corruption is surfaced. Returns non-zero on any failure.
# Emits a warning (and returns success) only when no DuckDB runtime exists.
verify_duckdb_file() {
  local db_path="$1"
  local python_bin=""
  if ! python_bin="$(command -v python3 2>/dev/null)" \
    && ! python_bin="$(command -v python 2>/dev/null)"; then
    echo "[WARN] No python runtime found; skipping backup verification." >&2
    log_jsonl "BACKUP_VERIFY_SKIPPED" "No python runtime for verification path=${db_path}" "OK"
    return 0
  fi
  local rc=0
  "$python_bin" - "$db_path" <<'PY' || rc=$?
import sys

try:
    import duckdb
except Exception:  # noqa: BLE001 — runtime not present; caller treats as skip
    sys.exit(97)

path = sys.argv[1]
try:
    con = duckdb.connect(path, read_only=True)
except Exception as exc:  # noqa: BLE001
    print(f"open failed: {type(exc).__name__}: {exc}", file=sys.stderr)
    sys.exit(1)
try:
    tables = con.execute(
        "SELECT table_name FROM information_schema.tables "
        "WHERE table_schema = 'main'"
    ).fetchall()
    for (name,) in tables:
        con.execute(f'SELECT count(*) FROM "{name}"').fetchone()
except Exception as exc:  # noqa: BLE001
    print(f"scan failed: {type(exc).__name__}: {exc}", file=sys.stderr)
    sys.exit(1)
finally:
    con.close()
print(f"verified tables={len(tables)}")
sys.exit(0)
PY
  if [ "$rc" -eq 97 ]; then
    echo "[WARN] duckdb python module not available; skipping backup verification." >&2
    log_jsonl "BACKUP_VERIFY_SKIPPED" "duckdb module missing for verification path=${db_path}" "OK"
    return 0
  fi
  return "$rc"
}

backup_sqlite_file() {
  local source_path="$1"
  local destination_path="$2"
  local python_bin=""
  if ! python_bin="$(command -v python3 2>/dev/null)" \
    && ! python_bin="$(command -v python 2>/dev/null)"; then
    echo "[FAIL] Python is required to snapshot the provisioning queue." >&2
    return 1
  fi
  "$python_bin" - "$source_path" "$destination_path" <<'PY'
import sqlite3
import sys

source_path, destination_path = sys.argv[1:]
source = sqlite3.connect(f"file:{source_path}?mode=ro", uri=True)
destination = sqlite3.connect(destination_path)
try:
    source.backup(destination)
finally:
    destination.close()
    source.close()
PY
}

verify_sqlite_file() {
  local database_path="$1"
  local python_bin=""
  if ! python_bin="$(command -v python3 2>/dev/null)" \
    && ! python_bin="$(command -v python 2>/dev/null)"; then
    echo "[FAIL] Python is required to verify the provisioning queue." >&2
    return 1
  fi
  "$python_bin" - "$database_path" <<'PY'
import sqlite3
import sys

database_path = sys.argv[1]
connection = sqlite3.connect(f"file:{database_path}?mode=ro", uri=True)
try:
    result = connection.execute("PRAGMA integrity_check").fetchone()[0]
    if result != "ok":
        raise RuntimeError(f"integrity check returned {result!r}")
finally:
    connection.close()
PY
}

# --- acquire the same exclusive writer lock (never bypassed) ---
mkdir -p "$(dirname "$LOCK_FILE")" 2>/dev/null || true
if ! eval "exec ${LOCK_FD}>\"${LOCK_FILE}\"" 2>/dev/null; then
  echo "[FAIL] Cannot open lock file for writing: $LOCK_FILE" >&2
  log_jsonl "BACKUP_FAILED" "Cannot open lock file lock_file=${LOCK_FILE}" "FAILED"
  exit 1
fi

if [ "$WAIT_SECONDS" -gt 0 ]; then
  lock_ok=false
  if flock -w "$WAIT_SECONDS" "$LOCK_FD"; then
    lock_ok=true
  fi
else
  lock_ok=false
  if flock -n "$LOCK_FD"; then
    lock_ok=true
  fi
fi

if [ "$lock_ok" != "true" ]; then
  echo "[FAIL] A writer job holds the pipeline lock ($LOCK_FILE). Backup aborted." >&2
  echo "       Retry after the writer finishes, or use --wait SECONDS." >&2
  log_jsonl "BACKUP_FAILED" "Backup blocked by active writer lock lock_file=${LOCK_FILE}" "FAILED"
  exit 1
fi

mkdir -p "$(dirname "$QUEUE_LOCK_FILE")" 2>/dev/null || true
if ! eval "exec ${QUEUE_LOCK_FD}>\"${QUEUE_LOCK_FILE}\"" 2>/dev/null; then
  echo "[FAIL] Cannot open provisioning lock for writing: $QUEUE_LOCK_FILE" >&2
  log_jsonl "BACKUP_FAILED" "Cannot open provisioning lock lock_file=${QUEUE_LOCK_FILE}" "FAILED"
  exit 1
fi
if [ "$WAIT_SECONDS" -gt 0 ]; then
  queue_lock_ok=false
  if flock -w "$WAIT_SECONDS" "$QUEUE_LOCK_FD"; then
    queue_lock_ok=true
  fi
else
  queue_lock_ok=false
  if flock -n "$QUEUE_LOCK_FD"; then
    queue_lock_ok=true
  fi
fi
if [ "$queue_lock_ok" != "true" ]; then
  echo "[FAIL] The provisioner holds the queue lock ($QUEUE_LOCK_FILE). Backup aborted." >&2
  echo "       Stop openstock-provisioner.service, or use --wait SECONDS." >&2
  log_jsonl "BACKUP_FAILED" "Backup blocked by active provisioner lock_file=${QUEUE_LOCK_FILE}" "FAILED"
  exit 1
fi

# Both locks are held for the remainder of the run; released automatically on exit.
if [ ! -f "$WAREHOUSE_PATH" ]; then
  echo "[FAIL] Warehouse not found at: $WAREHOUSE_PATH" >&2
  log_jsonl "BACKUP_FAILED" "Backup failed warehouse not found path=${WAREHOUSE_PATH}" "FAILED"
  exit 1
fi

mkdir -p "$BACKUP_DIR"

TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP_PATH="${BACKUP_DIR}/warehouse-${TIMESTAMP}.duckdb"
TMP_BACKUP_PATH="${BACKUP_PATH}.partial"
QUEUE_BACKUP_PATH="${BACKUP_PATH%.duckdb}.queue.sqlite3"
QUEUE_ABSENT_PATH="${BACKUP_PATH%.duckdb}.queue.absent"
TMP_QUEUE_BACKUP_PATH="${QUEUE_BACKUP_PATH}.partial"
TMP_QUEUE_ABSENT_PATH="${QUEUE_ABSENT_PATH}.partial"

echo "[INFO] Backing up $WAREHOUSE_PATH -> $BACKUP_PATH"
log_jsonl "BACKUP_STARTED" "Backup started src=${WAREHOUSE_PATH} dest=${BACKUP_PATH}" "STARTED"

# Copy to a .partial file first so an interrupted copy never looks like a
# finished backup. The exclusive lock guarantees no writer mutates the source.
if ! cp "$WAREHOUSE_PATH" "$TMP_BACKUP_PATH" 2>/dev/null; then
  echo "[FAIL] Backup copy failed: $WAREHOUSE_PATH -> $TMP_BACKUP_PATH" >&2
  rm -f "$TMP_BACKUP_PATH" 2>/dev/null || true
  log_jsonl "BACKUP_FAILED" "Backup copy failed src=${WAREHOUSE_PATH} dest=${BACKUP_PATH}" "FAILED"
  exit 1
fi

if [ "$FORCE" = "true" ]; then
  echo "[WARN] --force: skipping backup verification."
  log_jsonl "BACKUP_VERIFY_SKIPPED" "Verification skipped by --force dest=${BACKUP_PATH}" "OK"
else
  echo "[INFO] Verifying backup integrity (read-only scan): $TMP_BACKUP_PATH"
  if ! verify_duckdb_file "$TMP_BACKUP_PATH"; then
    echo "[FAIL] Backup verification failed; discarding corrupt copy." >&2
    rm -f "$TMP_BACKUP_PATH" 2>/dev/null || true
    log_jsonl "BACKUP_FAILED" "Backup verification failed dest=${BACKUP_PATH}" "FAILED"
    exit 1
  fi
  log_jsonl "BACKUP_VERIFIED" "Backup verified dest=${BACKUP_PATH}" "OK"
fi

# Create a matching SQLite snapshot while the provisioner lock is held. A
# marker records an intentionally absent queue so restore never guesses which
# durable state belongs with the warehouse backup.
QUEUE_STATE="absent"
if [ -e "$QUEUE_PATH" ]; then
  if [ ! -f "$QUEUE_PATH" ] || [ -L "$QUEUE_PATH" ]; then
    echo "[FAIL] Provisioning queue is not a regular file: $QUEUE_PATH" >&2
    log_jsonl "BACKUP_FAILED" "Queue is not a regular file path=${QUEUE_PATH}" "FAILED"
    exit 1
  fi
  echo "[INFO] Backing up provisioning queue: $QUEUE_PATH"
  if ! backup_sqlite_file "$QUEUE_PATH" "$TMP_QUEUE_BACKUP_PATH"; then
    rm -f "$TMP_BACKUP_PATH" "$TMP_QUEUE_BACKUP_PATH" 2>/dev/null || true
    log_jsonl "BACKUP_FAILED" "Queue backup failed src=${QUEUE_PATH}" "FAILED"
    exit 1
  fi
  if [ "$FORCE" != "true" ] && ! verify_sqlite_file "$TMP_QUEUE_BACKUP_PATH"; then
    rm -f "$TMP_BACKUP_PATH" "$TMP_QUEUE_BACKUP_PATH" 2>/dev/null || true
    log_jsonl "BACKUP_FAILED" "Queue backup verification failed src=${QUEUE_PATH}" "FAILED"
    exit 1
  fi
  QUEUE_STATE="present"
else
  : > "$TMP_QUEUE_ABSENT_PATH"
fi

# Publish the queue companion before the warehouse. The warehouse file is the
# discoverable entry point, so a failed companion publish never advertises an
# incomplete pair to --latest.
if [ "$QUEUE_STATE" = "present" ]; then
  if ! mv -f "$TMP_QUEUE_BACKUP_PATH" "$QUEUE_BACKUP_PATH" 2>/dev/null; then
    rm -f "$TMP_BACKUP_PATH" "$TMP_QUEUE_BACKUP_PATH" 2>/dev/null || true
    log_jsonl "BACKUP_FAILED" "Queue backup finalize failed dest=${QUEUE_BACKUP_PATH}" "FAILED"
    exit 1
  fi
else
  if ! mv -f "$TMP_QUEUE_ABSENT_PATH" "$QUEUE_ABSENT_PATH" 2>/dev/null; then
    rm -f "$TMP_BACKUP_PATH" "$TMP_QUEUE_ABSENT_PATH" 2>/dev/null || true
    log_jsonl "BACKUP_FAILED" "Queue absence marker finalize failed dest=${QUEUE_ABSENT_PATH}" "FAILED"
    exit 1
  fi
fi

# Atomically publish the verified warehouse under its final name.
if ! mv -f "$TMP_BACKUP_PATH" "$BACKUP_PATH" 2>/dev/null; then
  echo "[FAIL] Could not finalize backup: $TMP_BACKUP_PATH -> $BACKUP_PATH" >&2
  rm -f "$TMP_BACKUP_PATH" 2>/dev/null || true
  log_jsonl "BACKUP_FAILED" "Backup finalize failed dest=${BACKUP_PATH}" "FAILED"
  exit 1
fi

echo "[OK] Backup created: $BACKUP_PATH (queue=${QUEUE_STATE})"
log_jsonl "BACKUP_CREATED" "Backup created dest=${BACKUP_PATH} queue_state=${QUEUE_STATE}" "OK"
