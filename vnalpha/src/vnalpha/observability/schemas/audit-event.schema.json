{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuditEvent",
  "description": "Meaningful user/system activity trail event",
  "type": "object",
  "required": ["event_id", "run_id", "created_at", "level", "event_type", "correlation_id"],
  "properties": {
    "event_id": {"type": "string"},
    "run_id": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "level": {"type": "string"},
    "event_type": {"type": "string"},
    "surface": {"type": "string"},
    "actor": {"type": "string"},
    "correlation_id": {"type": "string"},
    "status": {"type": "string"},
    "summary": {"type": "string"},
    "redaction_status": {"type": "string"},
    "metadata": {"type": "object"}
  }
}
