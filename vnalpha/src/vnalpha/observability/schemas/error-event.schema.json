{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ErrorEvent",
  "description": "Exception, warning, or degraded-behavior event",
  "type": "object",
  "required": ["event_id", "run_id", "created_at", "level", "event_type", "correlation_id", "error_type", "error_message"],
  "properties": {
    "event_id": {"type": "string"},
    "run_id": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "level": {"type": "string"},
    "event_type": {"type": "string"},
    "surface": {"type": "string"},
    "correlation_id": {"type": "string"},
    "error_type": {"type": "string"},
    "error_message": {"type": "string"},
    "module": {"type": "string"},
    "function": {"type": "string"},
    "stacktrace": {"type": "string"},
    "stacktrace_hash": {"type": "string"},
    "likely_cause": {"type": "string"},
    "suggested_next_step": {"type": "string"},
    "redaction_status": {"type": "string"}
  }
}
