# openstock environment
# Copy to .env and fill in values

# vnstock-service base URL (default: localhost)
VNSTOCK_SERVICE_URL=http://127.0.0.1:6900

# vnalpha warehouse path (DuckDB file, default: ~/.local/share/vnalpha/warehouse.duckdb)
VNALPHA_WAREHOUSE_PATH=~/.local/share/vnalpha/warehouse.duckdb

# Default universe for sync/features/scoring
VNALPHA_UNIVERSE=VN30

# Log level
VNALPHA_LOG_LEVEL=INFO
