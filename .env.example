# OpenStock environment template
# Copy to .env and fill in deployment-specific values.
# Do not commit .env because it may contain secrets.

# ── Canonical single-host paths ───────────────────────────────────────────────
# The Docker worker and the host-installed TUI must use the same DuckDB file.
OPENSTOCK_WAREHOUSE_DIR=/var/lib/openstock/warehouse
VNSTOCK_CONFIG_DIR=/var/lib/openstock/vnstock-config
VNALPHA_WAREHOUSE_PATH=/var/lib/openstock/warehouse/warehouse.duckdb
VNSTOCK_SERVICE_URL=http://127.0.0.1:6900

# ── vnalpha defaults ──────────────────────────────────────────────────────────
VNALPHA_UNIVERSE=VN30
VNALPHA_LOG_LEVEL=INFO

# ── Optional FiinQuantX runtime ───────────────────────────────────────────────
# Keep disabled until the exact SDK, credentials, entitlement and commercial
# policy have been reviewed. Persistence requires a separate explicit decision.
VNSTOCK_INSTALL_FIINQUANTX=false
VNSTOCK_FIINQUANTX_LICENSED=false
VNALPHA_FIINQUANTX_PERSISTENCE_APPROVED=false
FIINQUANT_USERNAME=
FIINQUANT_PASSWORD=

# ── Optional LLM gateway and model routing ────────────────────────────────────
# Leave endpoint and model IDs blank until they are verified in the deployed
# gateway. Example after approval: http://ya-router:7071/v1/chat/completions
# Deterministic research functions continue to work with the assistant disabled.
# MVP1 needs one verified model alias. After setting these, run
# `vnalpha preflight` to verify endpoint reachability, the model route and the
# structured-output capability; it prints a typed, secret-free diagnostic.
VNALPHA_LLM_ENDPOINT=
VNALPHA_LLM_MODEL=
VNALPHA_LLM_API_KEY=
VNALPHA_LLM_TIMEOUT=30
VNALPHA_LLM_MAX_OUTPUT_TOKENS=1024
VNALPHA_LLM_MAX_RETRIES=2
VNALPHA_LLM_STORE_RAW=false

# Optional profile-specific routes. Same-model profiles are reported truthfully
# as single-model routing rather than as effective fallbacks.
VNALPHA_MODEL_DEFAULT=
VNALPHA_MODEL_SMALL=
VNALPHA_MODEL_REASONING=
VNALPHA_MODEL_LONG_CONTEXT=
VNALPHA_MODEL_FALLBACK_REASONING=default,small
VNALPHA_MODEL_FALLBACK_LONG_CONTEXT=reasoning,default
VNALPHA_MODEL_FALLBACK_DEFAULT=small

# Capabilities are explicit and fail closed. Strict JSON Schema requests may use
# a fallback only when that profile declares json_schema here. Do not infer
# capabilities from provider or model names.
VNALPHA_MODEL_CAPABILITIES_SMALL=
VNALPHA_MODEL_CAPABILITIES_DEFAULT=
VNALPHA_MODEL_CAPABILITIES_REASONING=
VNALPHA_MODEL_CAPABILITIES_LONG_CONTEXT=
VNALPHA_MODEL_ALLOW_RAW_OVERRIDE=false
