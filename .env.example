# openstock environment template
# Copy to .env and fill in values.
# Do NOT commit .env (it may contain secrets).

# ── vnstock-service ──────────────────────────────────────────────────────────
# Host-direct URL (default, for local Python / TUI use):
VNSTOCK_SERVICE_URL=http://127.0.0.1:6900
# Docker inter-container URL (used by vnalpha-worker via docker-compose.yml):
# VNSTOCK_SERVICE_URL=http://vnstock-service:6900

# ── vnalpha warehouse ────────────────────────────────────────────────────────
# Local path (default, for local Python / TUI / deb install):
VNALPHA_WAREHOUSE_PATH=~/.local/share/vnalpha/warehouse.duckdb
# Docker worker path (set in docker-compose.yml for vnalpha-worker):
# VNALPHA_WAREHOUSE_PATH=/warehouse/warehouse.duckdb

# ── vnalpha universe ─────────────────────────────────────────────────────────
VNALPHA_UNIVERSE=VN30

# ── LLM gateway (vnalpha assistant — optional) ───────────────────────────────
# VNALPHA_LLM_ENDPOINT=https://lite.x51.vn/v1/chat/completions
# VNALPHA_LLM_MODEL=claude-sonnet-4-6
# VNALPHA_LLM_API_KEY=
# VNALPHA_LLM_TIMEOUT=30
# VNALPHA_LLM_MAX_OUTPUT_TOKENS=1024
# VNALPHA_LLM_MAX_RETRIES=2
# VNALPHA_LLM_STORE_RAW=false

# ── logging ──────────────────────────────────────────────────────────────────
VNALPHA_LOG_LEVEL=INFO
