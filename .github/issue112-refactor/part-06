+def _refresh_current_revision_statuses(
+    conn: duckdb.DuckDBPyConnection,
+    *,
+    action_id: str,
+    preferred_revision_id: str,
+) -> bool:
+    current = conn.execute(
+        """SELECT revision_id
+           FROM corporate_action
+           WHERE action_id=? AND canonical_status IN ('ACTIVE', 'CONFLICT')""",
+        [action_id],
+    ).fetchall()
+    current_ids = [row[0] for row in current]
+    conflict = any(revision_id != preferred_revision_id for revision_id in current_ids)
+    status = "CONFLICT" if conflict else "ACTIVE"
+    conn.execute(
+        "UPDATE corporate_action SET canonical_status=? WHERE revision_id=?",
+        [status, preferred_revision_id],
+    )
+    if conflict:
+        conn.execute(
+            """UPDATE corporate_action SET canonical_status='CONFLICT'
+               WHERE action_id=? AND revision_id<>?
+                 AND canonical_status IN ('ACTIVE', 'CONFLICT')""",
+            [action_id, preferred_revision_id],
+        )
+    return conflict
