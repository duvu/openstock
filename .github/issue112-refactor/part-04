+"""Canonical validation, revisioning and conflict reconciliation for actions."""
+
+from __future__ import annotations
+
+import hashlib
+import json
+import uuid
+from collections.abc import Mapping
+from dataclasses import dataclass
+from datetime import date
+from typing import Any
+
+import duckdb
+
+CONTRACT_VERSION = "corporate-actions-v1"
+SUPPORTED_ACTION_TYPES = frozenset(
+    {
+        "CASH_DIVIDEND",
+        "STOCK_DIVIDEND",
+        "STOCK_BONUS",
+        "SPLIT",
+        "CONSOLIDATION",
+        "RIGHTS_ISSUE",
+        "REFERENCE_PRICE_ADJUSTMENT",
+        "ADDITIONAL_LISTING",
+        "SYMBOL_CHANGE",
+        "DELISTING",
+    }
+)
+_RATIO_ACTIONS = frozenset(
+    {"STOCK_DIVIDEND", "STOCK_BONUS", "SPLIT", "CONSOLIDATION", "RIGHTS_ISSUE"}
+)
+
+
+@dataclass(frozen=True)
+class _RecordOutcome:
+    outcome: str
+    raw_inserted: bool
+    conflict: bool = False
+    affected: bool = False
+
+
+def _ingest_record(
+    conn: duckdb.DuckDBPyConnection,
+    *,
+    run_id: str,
+    provider: str,
+    requested_symbol: str,
+    record: Mapping[str, Any],
+) -> _RecordOutcome:
+    raw = dict(record)
+    provider_event_id = str(raw.get("provider_event_id") or "").strip()
+    content_hash = str(raw.get("content_hash") or "").strip()
+    payload_json = str(
+        raw.get("source_payload_json") or json.dumps(raw, sort_keys=True)
+    )
+    raw_evidence_id = _sha256(provider, provider_event_id, content_hash)
+    before = conn.execute(
+        "SELECT 1 FROM corporate_action_raw_evidence WHERE raw_evidence_id = ?",
+        [raw_evidence_id],
+    ).fetchone()
+    conn.execute(
+        """
+        INSERT OR IGNORE INTO corporate_action_raw_evidence
+        (raw_evidence_id, ingestion_run_id, provider, provider_event_id, symbol,
+         source_reference, source_version, content_hash, payload_json, quality_status, diagnostics_json)
+        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+        """,
+        [
+            raw_evidence_id,
+            run_id,
+            provider,
+            provider_event_id,
+            str(raw.get("symbol") or requested_symbol).upper(),
+            str(raw.get("source_reference") or ""),
+            str(raw.get("source_version") or CONTRACT_VERSION),
+            content_hash,
+            payload_json,
+            raw.get("quality_status"),
+            None,
+        ],
+    )
+    if before is not None:
+        return _RecordOutcome("unchanged", False)
+
