+def _revision_hash(record: Mapping[str, Any]) -> str:
+    keys = (
+        "symbol",
+        "action_type",
+        "ex_date",
+        "record_date",
+        "effective_date",
+        "cash_amount",
+        "ratio",
+        "ratio_text",
+        "subscription_price",
+        "reference_price",
+        "currency",
+    )
