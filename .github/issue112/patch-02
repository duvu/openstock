+def _insert_affected_range(
+    conn: duckdb.DuckDBPyConnection,
+    *,
+    action_id: str,
+    revision_id: str,
+    symbol: str,
+    affected_from: date | str,
+    reason: str,
+) -> None:
+    conn.execute(
+        """INSERT INTO corporate_action_affected_range
+           (signal_id, action_id, revision_id, symbol, affected_from_date, reason)
+           VALUES (?, ?, ?, ?, ?, ?)""",
+        [str(uuid.uuid4()), action_id, revision_id, symbol, affected_from, reason],
+    )
+
