+def _validation_rules(
+    conn: duckdb.DuckDBPyConnection, record: Mapping[str, Any], *, requested_symbol: str
+) -> list[str]:
+    rules: list[str] = []
+    symbol = str(record.get("symbol") or requested_symbol).strip().upper()
+    if not record.get("provider_event_id"):
+        rules.append("MISSING_PROVIDER_EVENT_ID")
+    if not record.get("content_hash"):
+        rules.append("MISSING_CONTENT_HASH")
+    if not record.get("source_reference"):
+        rules.append("MISSING_SOURCE_REFERENCE")
+    if not record.get("source_version"):
+        rules.append("MISSING_SOURCE_VERSION")
+    if symbol != requested_symbol.strip().upper():
+        rules.append("SYMBOL_MISMATCH")
+    action_type = str(record.get("action_type") or "")
+    if action_type not in SUPPORTED_ACTION_TYPES:
+        rules.append("UNSUPPORTED_ACTION_TYPE")
+    if _anchor_date(record) is None:
+        rules.append("MISSING_ACTION_DATE")
+    if action_type == "CASH_DIVIDEND" and not _positive(record.get("cash_amount")):
+        rules.append("INVALID_CASH_AMOUNT")
+    if action_type in _RATIO_ACTIONS and not _positive(record.get("ratio")):
+        rules.append("INVALID_RATIO")
